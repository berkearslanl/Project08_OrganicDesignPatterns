<body>
    <!-- body wrap start -->
    <div class="body-wrap overflow-hidden">
        <!-- back-to-top start -->
        <div class="backtotop">
            <a href="#!" class="scroll">
                <i class="far fa-arrow-up fw-bold"></i>
            </a>
        </div>
        <!-- back-to-top end -->
        @await Component.InvokeAsync("Header")

        <!-- main body start -->
        <main>

            <!-- sidebar section start -->
            <!-- Breadcrumb section start -->
            <section class="breadcrumb_sec_1 position-relative">
                <div class="breadcrumb_wrap sec_space_mid_small"
                     style="background-image: url(/organic-html/assets/images/breadcrumb/breadcrumb1.png);">
                    <div class="breadcrumb_cont text-center">
                        <div class="breadcrumb_title">
                            <h2 class="text-white">Sepet Sayfası</h2>
                        </div>
                        <ul class="list-unstyled breadcrumb_item d-flex justify-content-center align-items-center text-white">
                            <li><a href="index.html"><i class="fas fa-home active"></i>Anasayfa</a></li>
                            <li><i class="fas fa-chevron-right"></i>Hakkımızda</li>
                            <li><i class="fas fa-chevron-right"></i>Kuru Ürünler</li>
                        </ul>
                    </div>
                </div>
            </section>
            <!-- Breadcrumb section end -->
            <!-- cart_section - start -->
            <section class="cart_section sec_space_large" data-aos="fade-up"
                     data-aos-duration="2000">
                <div class="container">
                    <div class="cart_table table-responsive position-relative">
                        <table class="table align-middle">
                            <thead class="text-uppercase">
                                <tr>
                                    <th>Fotoğraf</th>
                                    <th>Ürün Adı</th>
                                    <th>Fiyat</th>
                                    <th>Adet</th>
                                    <th>Toplam</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model == null || !Model.CartItems.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <h5>Sepetiniz boş!</h5>
                                            <a asp-action="ShopList" asp-controller="Shop"
                                               class="btn custom_btn rounded-pill px-4 mt-3 text-white">
                                                Alışverişe Devam Et
                                            </a>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var x in Model.CartItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="cart_product position-relative">
                                                    <div class="item_image">
                                                        <img src="@x.Product.ImageUrl" alt="@x.Product.ProductName"
                                                             style="width: 80px; height: 80px; object-fit: contain; mix-blend-mode: multiply;">
                                                    </div>
                                                    <form asp-action="RemoveItem" asp-controller="Cart" method="post">
                                                        <input type="hidden" name="cartItemId" value="@x.CartItemId">
                                                        <button type="submit" class="remove_btn position-absolute">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="item_content">
                                                    <a href="/Shop/ProductDetail/@x.ProductId">
                                                        <h4 class="item_title">@x.Product.ProductName</h4>
                                                    </a>
                                                    <span class="item_type">@x.Product.Category.CategoryName</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="price_text">@x.Product.Price.ToString("C2")</span>
                                            </td>
                                            <td>
                                                <form asp-action="UpdateQuantity" asp-controller="Cart" method="post">
                                                    <input type="hidden" name="cartItemId" value="@x.CartItemId">
                                                    <div class="quantity_input">
                                                        <span class="input_number_decrement">–</span>
                                                        <input class="input_number" type="number"
                                                               name="quantity" value="@x.Quantity" min="1">
                                                        <span class="input_number_increment">+</span>
                                                    </div>
                                                    <button type="submit" class="btn btn-sm mt-1"
                                                            style="font-size:11px;">
                                                        Güncelle
                                                    </button>
                                                </form>
                                            </td>
                                            <td>
                                                <span class="total_price">
                                                    @((x.Product.Price * x.Quantity).ToString("C2"))
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }

                            </tbody>
                        </table>
                    </div>

                    <div class="coupon_wrap d-flex justify-content-between">
                        <div class="coupon_form d-flex align-items-center">
                            <div class="form_item mb-0 me-5">
                                <input type="text" class="coupon rounded-pill" placeholder="Kupon Kodu">
                            </div>
                            <button type="submit"
                                    class="btn btn_coupon custom_btn text-white rounded-pill py-2 py-sm-3 px-3 px-sm-5 text-uppercase">
                                Kuponu Uygula
                            </button>
                        </div>
                        <button type="button"
                                class="btn coupon_update_btn text-white rounded-pill py-2 py-sm-3 px-3 px-sm-5 text-uppercase">
                            Sepeti Güncelle
                        </button>
                    </div>

                    @if (Model != null && Model.CartItems.Any())
                    {
                        var total = Model.CartItems.Sum(i => i.Product.Price * i.Quantity);

                        <div class="row justify-content-lg-end">
                            <div class="col col-lg-4 mt-5">
                                <div class="cart_pricing_table text-uppercase">
                                    <h3 class="table_title text-center">Sepet Toplamı</h3>
                                    <ul class="ul_li_block clearfix">
                                        <li>
                                            <span>Ara Toplam</span>
                                            <span>@total.ToString("C2")</span>
                                        </li>
                                        <li>
                                            <span>Toplam</span>
                                            <span>@total.ToString("C2")</span>
                                        </li>
                                    </ul>
                                    <div class="btn_wrap pt-0 text-center">
                                        <a href="/Checkout/Index" class="btn text-uppercase text-white rounded-pill">
                                            Ödemeye Geç
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
            <!-- cart_section - end -->

