    <link rel="stylesheet" href="/organic-html/assets/css/bootstrap.min.css">

    <!-- Include aos CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/aos.css">

    <!-- Include magnific-popup CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/magnific-popup.css">

    <!-- Include nice-select CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/nice-select.css">

    <!-- Include slick-theme CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/slick-theme.css">

    <!-- Include slick CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/slick.css">

    <!-- Include stylesheet CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/style.css">

