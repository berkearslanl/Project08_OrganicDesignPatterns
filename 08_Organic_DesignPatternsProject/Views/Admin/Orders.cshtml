@model List<Order>
@using _08_Organic_DesignPatternsProject.State
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Siparişler";
    ViewBag.Subtitle = "Tüm siparişleri görüntüle ve yönet";
    ViewBag.ActiveMenu = "orders";
}

<div class="admin-card">
    <div class="card-header">
        <span><i class="fas fa-shopping-bag me-2" style="color:#5cb85c;"></i>Sipariş Listesi</span>
    </div>
    <div class="card-body p-0">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>Sipariş No</th>
                    <th>Müşteri</th>
                    <th>E-posta</th>
                    <th>Tutar</th>
                    <th>Ödeme</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    var ctx = ((Dictionary<int, OrderContext>)ViewBag.Contexts)[order.OrderId];

                    <tr>
                        <td><span style="font-weight:700;color:#5cb85c;">#@order.OrderId</span></td>
                        <td style="font-weight:600;">@order.CustomerName</td>
                        <td style="color:#94a3b8;">@order.CustomerEmail</td>
                        <td style="font-weight:600;">@order.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td>@order.PaymentMethod</td>
                        <td>
                            <span class="status-badge @ctx.CurrentBadgeClass">
                                @ctx.CurrentStateName
                            </span>
                        </td>
                        <td style="color:#94a3b8;">@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex gap-1">

                                @if (ctx.CanShip)
                                {
                                    <form asp-action="UpdateOrderStatus" asp-controller="Admin" method="post" class="d-inline">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <input type="hidden" name="action" value="ship" />
                                        <button type="submit" class="btn-icon btn-icon-edit" title="Kargoya Ver">
                                            <i class="fas fa-truck"></i>
                                        </button>
                                    </form>
                                }

                                @if (ctx.CanDeliver)
                                {
                                    <form asp-action="UpdateOrderStatus" asp-controller="Admin" method="post" class="d-inline">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <input type="hidden" name="action" value="deliver" />
                                        <button type="submit" class="btn-icon btn-icon-view" title="Teslim Edildi">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                }

                                @if (ctx.CanCancel)
                                {
                                    <form asp-action="UpdateOrderStatus" asp-controller="Admin" method="post" class="d-inline"
                                          onsubmit="return confirm('Siparişi iptal etmek istediğinize emin misiniz?')">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <input type="hidden" name="action" value="cancel" />
                                        <button type="submit" class="btn-icon btn-icon-delete" title="İptal Et">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                }

                                @if (!ctx.CanShip && !ctx.CanDeliver && !ctx.CanCancel)
                                {
                                    <span style="font-size:12px;color:#94a3b8;">—</span>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>