@model Quality
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Kalite Bölümü";
    ViewBag.Subtitle = "Ana sayfadaki kalite bölümü içeriğini düzenle";
    ViewBag.ActiveMenu = "quality";
}

<div class="admin-card">
    <div class="card-header">
        <span><i class="fas fa-award me-2" style="color:#5cb85c;"></i>Kalite Bölümü Düzenle</span>
    </div>
    <div class="card-body">
        <form asp-action="UpdateQuality" asp-controller="Admin" method="post">
            <input type="hidden" name="QualityId" value="@Model?.QualityId" />

            <!-- Genel -->
            <div class="row g-3 mb-4">
                <div class="col-12">
                    <h6 style="font-weight:700;color:#1e293b;border-bottom:2px solid #f1f5f9;padding-bottom:8px;">
                        <i class="fas fa-heading me-2" style="color:#5cb85c;"></i>Genel Bilgiler
                    </h6>
                </div>
                <div class="col-md-6">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Ana Başlık</label>
                    <input type="text" name="MainTitle" value="@Model?.MainTitle" class="form-control" placeholder="Ürün Kalitemiz" style="border-radius:10px;font-size:14px;" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Merkez Görsel URL</label>
                    <input type="text" name="MainImageUrl" value="@Model?.MainImageUrl" class="form-control" placeholder="/images/category/cat13.png" style="border-radius:10px;font-size:14px;" />
                </div>
            </div>

            <!-- 4 Öğe -->
            @for (int i = 1; i <= 4; i++)
            {
                var label = i == 1 ? Model?.Item1Label : i == 2 ? Model?.Item2Label : i == 3 ? Model?.Item3Label : Model?.Item4Label;
                var desc = i == 1 ? Model?.Item1Description : i == 2 ? Model?.Item2Description : i == 3 ? Model?.Item3Description : Model?.Item4Description;
                var img = i == 1 ? Model?.Item1ImageUrl : i == 2 ? Model?.Item2ImageUrl : i == 3 ? Model?.Item3ImageUrl : Model?.Item4ImageUrl;
                var position = i <= 2 ? "Sol" : "Sağ";
                <div class="row g-3 mb-3">
                    <div class="col-12">
                        <h6 style="font-weight:700;color:#1e293b;border-bottom:2px solid #f1f5f9;padding-bottom:8px;">
                            <i class="fas fa-circle me-2" style="color:#5cb85c;font-size:10px;"></i>
                            @i. Öğe <span class="status-badge status-blue ms-2">@position</span>
                        </h6>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Etiket</label>
                        <input type="text" name="Item@(i)Label" value="@label" class="form-control" placeholder="Örn: İçindekiler" style="border-radius:10px;font-size:14px;" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Açıklama</label>
                        <input type="text" name="Item@(i)Description" value="@desc" class="form-control" placeholder="Kısa açıklama" style="border-radius:10px;font-size:14px;" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Görsel URL</label>
                        <input type="text" name="Item@(i)ImageUrl" value="@img" class="form-control" placeholder="/images/cat.png" style="border-radius:10px;font-size:14px;" />
                    </div>
                </div>
            }

            <div class="mt-3">
                <button type="submit" class="btn btn-green px-5">
                    <i class="fas fa-save me-2"></i> Kaydet
                </button>
            </div>
        </form>
    </div>
</div>
