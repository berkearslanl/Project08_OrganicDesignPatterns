@model List<Banner>
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Banner Yönetimi";
    ViewBag.Subtitle = "Ana sayfa banner'larını ekle ve düzenle";
    ViewBag.ActiveMenu = "banners";
}

<!-- BANNER EKLE -->
<div class="admin-card mb-4">
    <div class="card-header">
        <span><i class="fas fa-plus-circle me-2" style="color:#5cb85c;"></i>Yeni Banner Ekle</span>
    </div>
    <div class="card-body">
        <form asp-action="CreateBanner" asp-controller="Admin" method="post">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Üst Başlık</label>
                    <input type="text" name="ShortTitle" class="form-control" placeholder="Örn: ORGANİK ÜRÜNLER" style="border-radius:10px;font-size:14px;" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Ana Başlık</label>
                    <input type="text" name="Title" class="form-control" placeholder="Banner başlığı" style="border-radius:10px;font-size:14px;" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Görsel URL</label>
                    <input type="text" name="ImageUrl" class="form-control" placeholder="/images/banner.png" style="border-radius:10px;font-size:14px;" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-green w-100">
                        <i class="fas fa-plus me-1"></i> Ekle
                    </button>
                </div>
                <div class="col-md-10">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Açıklama</label>
                    <input type="text" name="Description" class="form-control" placeholder="Banner açıklaması" style="border-radius:10px;font-size:14px;" />
                </div>
            </div>
        </form>
    </div>
</div>

<!-- BANNER LİSTESİ -->
<div class="admin-card">
    <div class="card-header">
        <span><i class="fas fa-image me-2" style="color:#5cb85c;"></i>Banner Listesi</span>
        <span style="font-size:13px;color:#94a3b8;">@Model.Count banner</span>
    </div>
    <div class="card-body p-0">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>Üst Başlık</th>
                    <th>Ana Başlık</th>
                    <th>Açıklama</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" alt="@item.Title"
                                 style="width:80px;height:44px;object-fit:cover;border-radius:8px;background:#f8f9fa;" />
                        </td>
                        <td style="color:#5cb85c;font-size:13px;">@item.ShortTitle</td>
                        <td style="font-weight:600;">@item.Title</td>
                        <td style="color:#64748b;font-size:13px;">
                            @(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)
                        </td>
                        <td>
                            <form asp-action="DeleteBanner" asp-controller="Admin" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu banner\'ı silmek istediğinize emin misiniz?')">
                                <input type="hidden" name="id" value="@item.BannerId" />
                                <button type="submit" class="btn-icon btn-icon-delete" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
