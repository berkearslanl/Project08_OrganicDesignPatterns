@model List<Gallery>
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Galeri Yönetimi";
    ViewBag.Subtitle = "Ana sayfadaki Instagram/galeri görsellerini ekle ve yönet";
    ViewBag.ActiveMenu = "gallery";
}

<!-- GÖRSEL EKLE -->
<div class="admin-card mb-4">
    <div class="card-header">
        <span><i class="fas fa-plus-circle me-2" style="color:#5cb85c;"></i>Yeni Görsel Ekle</span>
    </div>
    <div class="card-body">
        <form asp-action="CreateGallery" asp-controller="Admin" method="post">
            <div class="row g-3">
                <div class="col-md-10">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">Görsel URL</label>
                    <input type="text" name="ImageUrl" class="form-control" placeholder="/images/instagram/insta1.jpg" style="border-radius:10px;font-size:14px;" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-green w-100">
                        <i class="fas fa-plus me-1"></i> Ekle
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- GALERİ LİSTESİ -->
<div class="admin-card">
    <div class="card-header">
        <span><i class="fab fa-instagram me-2" style="color:#5cb85c;"></i>Galeri Listesi</span>
        <span style="font-size:13px;color:#94a3b8;">@Model.Count görsel</span>
    </div>
    <div class="card-body p-0">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>URL</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" alt="Galeri Görseli"
                                 style="width:80px;height:55px;object-fit:cover;border-radius:8px;background:#f8f9fa;" />
                        </td>
                        <td style="color:#64748b;font-size:13px;">
                            @(item.ImageUrl?.Length > 50 ? item.ImageUrl.Substring(0, 50) + "..." : item.ImageUrl)
                        </td>
                        <td>
                            <form asp-action="DeleteGallery" asp-controller="Admin" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu görseli silmek istediğinize emin misiniz?')">
                                <input type="hidden" name="id" value="@item.GalleryId" />
                                <button type="submit" class="btn-icon btn-icon-delete" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
