@model List<Product>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mağaza Listesi - Organik - Gıda E-Ticaret</title>
    <!-- favicon icon -->
    <link rel="shortcut icon" href="/organic-html/assets/images/icons/favicon.ico" type="image/x-icon">

    <!-- Include fontawesome cdn -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
          integrity="sha512-Fo3rlrZj/k7ujTnHg4CGR2D7kSs0v4LLanw2qksYuRlEzO+tcaEPQogQ0KaoGN26/zrn20ImR1DfuLWnOo7aBA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Include google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Roboto:wght@400;500;700;900&display=swap"
          rel="stylesheet">

    <!-- Include bootstrap CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/bootstrap.min.css">

    <!-- Include aos CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/aos.css">

    <!-- Include magnific-popup CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/magnific-popup.css">

    <!-- Include nice-select CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/nice-select.css">

    <!-- Include slick CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/jquery-ui.css">

    <!-- Include slick-theme CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/slick-theme.css">

    <!-- Include slick CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/slick.css">

    <!-- Include stylesheet CSS -->
    <link rel="stylesheet" href="/organic-html/assets/css/style.css">

</head>

<body>
    <!-- body wrap start -->
    <div class="body-wrap overflow-hidden">
        <!-- back-to-top start -->
        <div class="backtotop">
            <a href="#!" class="scroll">
                <i class="far fa-arrow-up fw-bold"></i>
            </a>
        </div>
        <!-- back-to-top end -->
        @await Component.InvokeAsync("Header")

        <!-- main body start -->
        <main>
            <section class="breadcrumb_sec_1 position-relative">
                <div class="breadcrumb_wrap sec_space_mid_small"
                     style="background-image: url(/organic-html/assets/images/breadcrumb/breadcrumb1.png);">
                    <div class="breadcrumb_cont text-center">
                        <div class="breadcrumb_title">
                            <h2 class="text-white">Mağaza Listesi</h2>
                        </div>
                        <ul class="list-unstyled breadcrumb_item d-flex justify-content-center align-items-center text-white">
                            <li><a href="index.html"><i class="fas fa-home active"></i>Anasayfa</a></li>
                            <li><i class="fas fa-chevron-right"></i>Hakkımızda</li>
                            <li><i class="fas fa-chevron-right"></i>Kuru Ürünler</li>
                        </ul>
                    </div>
                </div>
            </section>
            <!-- Breadcrumb section end -->
            <!-- shop list sidebar start -->
            <section class="shop_list_sidebar sec_space_large">
                <div class="shop_sidebar_wrap">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-3">
                                <form method="get" asp-action="ShopList" asp-controller="Shop">
                                    <div class="shop_sidebar_searchbar position-relative">
                                        <input class="rounded-pill" type="search" name="search" placeholder="Ara">
                                        <i class="fas fa-search position-absolute"></i>
                                    </div>
                                    <!-- blog category start -->
                                    <div class="blog_category" data-aos="fade-up" data-aos-duration="2000">
                                        <div class="blog_category_wrap">
                                            <h3 class="blog_category_title py-3">Kategoriler</h3>
                                            <div class="blog_category_item">
                                                <div class="row">
                                                    <div class="form-check">
                                                        @foreach (var category in ViewBag.Categories)
                                                        {
                                                            <div class="col">
                                                                <input class="form-check-input" type="radio"
                                                                       name="categoryId" value="@category.CategoryId"
                                                                       id="cat_@category.CategoryId">
                                                                <label class="form-check-label ms-2" for="cat_@category.CategoryId">
                                                                    @category.CategoryName
                                                                </label>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- blog category end -->
                                    <!-- filter range start -->
                                    <div class="price-range-area mt-3" data-aos="fade-up" data-aos-duration="2000">
                                        <h3 class="price_range_title mb-4">Fiyata Göre Filtrele</h3>
                                        <div class="price-text d-flex align-items-center mt-3">
                                            <input type="number" name="minPrice" placeholder="Min ₺" class="form-control me-2">
                                            <input type="number" name="maxPrice" placeholder="Max ₺" class="form-control">
                                        </div>
                                    </div>
                                    <!-- filter range end -->
                                    <!-- trending section start -->
                                    <section class="trending_sec mt-3" data-aos="fade-up" data-aos-duration="2000">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="isOrganic" value="true" id="organicCheck">
                                            <label class="form-check-label ms-2" for="organicCheck">
                                                Sadece Organik Ürünler
                                            </label>
                                        </div>
                                    </section>
                                    <!-- trending section end -->
                                    <a asp-action="ShopList" asp-controller="Shop"
                                       class="btn btn-outline-secondary rounded-pill px-4 mt-2 w-100">
                                        Filtreyi Temizle <i class="fas fa-times"></i>
                                    </a>
                                    <button type="submit" class="btn custom_btn rounded-pill px-4 mt-3 text-white w-100">
                                        Filtrele <i class="fas fa-long-arrow-alt-right"></i>
                                    </button>

                                </form>
                            </div>
                            <div class="col-lg-9">
                                <!-- shop list section start -->
                                <section class="shop_list_sec" data-aos="fade-up" data-aos-duration="2000">
                                    <div class="shop_list_wrap">
                                        <div class="container">
                                            <div class="filter_area d-flex justify-content-between align-items-center mb_30">
                                                <ul class="nav layout_tab_nav ul_li" role="tablist">
                                                    <li>
                                                        <button class="active" data-bs-toggle="tab" data-bs-target="#grid_layout"
                                                                type="button" role="tab" aria-selected="true">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17"
                                                                 viewBox="0 0 12 12">
                                                                <path id="grid" class="cls-1"
                                                                      d="M1784,905h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-10,5h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-10,5h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Z"
                                                                      transform="translate(-1784 -905)" />
                                                            </svg>
                                                        </button>
                                                    </li>
                                                    <span class="show_result">@Model.Count sonuç gösteriliyor</span>
                                                </ul>
                                                <form action="#">
                                                    <div class="sorting_from d-flex align-items-center">
                                                        <span class="sorting_from_title">Varsayılan Sıralama:</span>
                                                        <div class=" clearfix">
                                                            <select>
                                                                <option data-display="Select">Nothing</option>
                                                                <option value="1" selected>Popülerlik</option>
                                                                <option value="2">Organik</option>
                                                                <option value="4">Fantastic</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                            <div class="shop_product_list">
                                                <div class="tab-content" id="pills-tabContent">
                                                    <div class="tab-pane fade show active" id="grid_layout" role="tabpanel"
                                                         aria-labelledby="pills-grid_layout-tab">
                                                        <div class="row g-4">
                                                            @foreach (var x in Model)
                                                            {
                                                                <div class="col-sm-6 col-lg-4">
                                                                    <div class="product_layout_1 overflow-hidden position-relative">
                                                                        <div class="product_layout_content bg-white position-relative">
                                                                            <div class="product_image_wrap">
                                                                                <a class="product_image d-flex justify-content-center align-items-center"
                                                                                   href="/Shop/ProductDetail/@x.ProductId" target="_blank">
                                                                                    <img class="pic-1" src="@x.ImageUrl"
                                                                                         alt="@x.ProductName">
                                                                                    <img class="pic-2" src="@x.ImageUrl"
                                                                                         alt="@x.ProductName">
                                                                                </a>
                                                                                <ul class="product_badge_group ul_li_block">
                                                                                    <li>
                                                                                        <span class="product_badge badge_meats position-absolute rounded-pill text-uppercase">@x.Category.CategoryName</span>
                                                                                    </li>
                                                                                    @if (x.IsOrganic == true)
                                                                                    {
                                                                                        <li>
                                                                                            <span class="product_badge badge_discount position-absolute rounded-pill">
                                                                                                Organik
                                                                                            </span>
                                                                                        </li>
                                                                                    }
                                                                                </ul>
                                                                                <ul class="product_action_btns ul_li_block d-flex">
                                                                                    <li>
                                                                                        <a class="tooltips" data-placement="top"
                                                                                           title="Ürünü İncele" href="/Shop/ProductDetail/@x.ProductId">
                                                                                            <i class="fas fa-search"></i>
                                                                                        </a>
                                                                                    </li>
                                                                                    <li>
                                                                                        <a class="tooltips" data-placement="top"
                                                                                           title="Sepete Ekle" href="/Cart/AddToCart/@x.ProductId"
                                                                                           data-bs-toggle="modal">
                                                                                            <i class="fas fa-shopping-bag"></i>
                                                                                        </a>
                                                                                    </li>
                                                                                </ul>
                                                                            </div>
                                                                            <div class="product_content">
                                                                                <h3 class="product_title">
                                                                                    <a href="/Shop/ProductDetail/@x.ProductId" target="_blank">
                                                                                        @x.ProductName
                                                                                    </a>
                                                                                </h3>
                                                                                <div class="product_price">
                                                                                    <span class="sale_price pe-1">@x.Price.ToString("C2")</span>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>
                                <!-- shop list section end -->
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- shop list sidebar end -->

        </main>
        <!-- main body end -->
        @await Component.InvokeAsync("Footer")
