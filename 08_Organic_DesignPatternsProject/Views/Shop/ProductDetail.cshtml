                                        <a href="#">
                                            <button type="button"
                                                    class="btn custom_btn rounded-pill px-4 text-white">
                                                @Model.Category.CategoryName
                                            </button>
                                        </a>
                                    </div>
                                </div>
                                <h2 class="product_detail_title">@Model.ProductName</h2>
                                <p class="product_detail_desc py-2">
                                    @Model.Description
                                </p>
                                <div class="row mt-5">
                                    <div class="col-lg-12">
                                        <div class="product10_value_content">
                                            <h4 class="value_title mb-3">Besin Değerleri:</h4>
                                            <div class="product10_value_table">
                                                <table class="table">
                                                    <tbody>
                                                        <tr>
                                                            <th scope="row">50G</th>
                                                            <td>Karbonhidrat</td>
                                                        </tr>
                                                        <tr>
                                                            <th scope="row">10G</th>
                                                            <td>Protein, Enerji</td>
                                                        </tr>
                                                        <tr>
                                                            <th scope="row">20G</th>
                                                            <td> Mineraller ve Vitaminler</td>
                                                        </tr>
                                                        <tr>
                                                            <th scope="row">90G</th>
                                                            <td>Besin Gereksinimleri</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <h4 class="mt-3" style="color: #4CAF50;">@Model.Price.ToString("C2")</h4>
                                <small class="text-muted d-block mb-3">Stokta: @Model.Stock adet</small>
                                <form asp-action="AddToCart" asp-controller="Cart" method="post">
                                    <input type="hidden" name="productId" value="@Model.ProductId">
                                    <div class="product10_quantity_btn_wrap d-flex align-items-center">
                                        <div class="quantity_input">
                                            <span class="input_number_decrement">–</span>
                                            <input class="input_number" type="number" name="quantity"
                                                   value="1" min="1" max="@Model.Stock">
                                            <span class="input_number_increment">+</span>
                                        </div>
                                        <button type="submit"
                                                class="btn custom_btn rounded-pill ms-3 px-5 py-3 text-white">
                                            Sepete Ekle <i class="fas fa-shopping-bag"></i>
                                        </button>
                                    </div>
                                </form>
                                <div class="product_tags_wrap d-flex align-items-center mt-5">
                                    <h6 class="product_tags_title text-uppercase">etiketler:</h6>
                                    <div class="tags_item d-flex align-items-center">
                                        <a href="#!">T-shirt,</a>
                                        <a class="ms-1" href="#!">Clothes,</a>
                                        <a class="ms-1" href="#!">Fashion,</a>
                                        <a class="ms-1" href="#!">Shop</a>
                                    </div>
                                </div>
                                <div class="product_social_links d-flex align-items-center">
                                    <h6 class="product_social_title text-uppercase">paylaş:</h6>
                                    <ul class="list-unstyled d-flex mb-0">
                                        <li><a href="#!"><i class="fab fa-facebook-f"></i></a></li>
                                        <li><a href="#!"><i class="fab fa-twitter"></i></a></li>
                                        <li><a href="#!"><i class="fab fa-google-plus-g"></i></a></li>
                                        <li><a href="#!"><i class="fab fa-pinterest-p"></i></a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
