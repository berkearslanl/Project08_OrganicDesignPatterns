                                        <img src="/organic-html/assets/images/product/product13.png" alt="image_not_found">
                                    </div>
                                    <div class="product10_back_thumb2 position-absolute">
                                        <img src="/organic-html/assets/images/shapes/shape24.png" alt="image_not_found">
                                    </div>
                                </div>
                                <div class="row align-items-center sec_top_space_70">
                                    <div class="col-lg-6">
