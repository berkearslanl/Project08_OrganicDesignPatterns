                                                                src="https://www.youtube.com/embed/UqyD2PgOw9Q"
                                                                frameborder="0" allowfullscreen>
                                                        </iframe>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
