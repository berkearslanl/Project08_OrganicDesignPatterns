                                                <img class="position-relative" src="/organic-html/assets/images/product/product20.png"
                                                     alt="image_not_found">
                                                <div class="product10_media_cont position-absolute d-flex flex-column align-items-center justify-content-center">
                                                    <a class="product10_media_icon" href="#!" data-bs-toggle="modal"
                                                       data-bs-target="#exampleModal3">
                                                        <i class="fas fa-play text-white"></i>
                                                    </a>
                                                    <a class="product10_media_title text-center text-white text-uppercase"
                                                       href="#!">Demo Video 1:30</a>
                                                </div>
                                            </div>
                                        </div>
